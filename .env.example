HOST=0.0.0.0
PORT=8787
PUBLIC_BASE_URL=https://sadgirlsclub.wtf/gmlapi
PUBLIC_BASE_PATH=/gmlapi
STORE_PATH=./data/store.json

STEAM_APP_ID=480
# You can allow multiple Steam app IDs by using a comma-separated list, e.g.
# STEAM_APP_ID=480,1234560
STEAM_WEB_API_KEY=
ALLOW_INSECURE_STEAM_AUTH=false
STEAM_TICKET_IDENTITY=spd-sgc-gateway

SGC_BASE_URL=http://127.0.0.1:7788/v1
SGC_API_KEY=
SGC_OAUTH_CLIENT_ID=
SGC_OAUTH_CLIENT_SECRET=
SGC_REDIRECT_URI=https://sadgirlsclub.wtf/gmlapi/sgc/link/callback
SGC_OAUTH_TOKEN_URL=http://127.0.0.1:7788/oauth/token
# Public origin to substitute when SGC returns authorize URLs that point at
# its internal loopback address. Leave empty to disable rewriting.
SGC_OAUTH_PUBLIC_BASE=https://sadgirlsclub.wtf
SGC_REQUESTED_SCOPE=balance:read

MATCH_TOKEN_TTL_MS=21600000
SESSION_TTL_MS=2592000000
MAX_PVE_KILLS_PER_MINUTE=120
MAX_PVP_KILLS_PER_MATCH=100
MIN_LEVEL_COMPLETE_MS=20000
